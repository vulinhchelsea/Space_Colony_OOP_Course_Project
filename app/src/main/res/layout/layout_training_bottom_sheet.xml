<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@drawable/bg_bottom_sheet">

    <!-- handle bar for visual cue -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="16dp"
        android:background="#E0E0E0" />

    <TextView
        android:id="@+id/bs_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="crew member name"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#212121" />

    <TextView
        android:id="@+id/bs_role"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="role: soldier"
        android:textColor="#757575"
        android:layout_marginBottom="16dp" />

    <TextView
        android:id="@+id/bs_stats"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#F5F5F5"
        android:padding="16dp"
        android:text="stats info"
        android:lineSpacingExtra="4dp"
        android:fontFamily="monospace"
        android:textColor="#424242" />

    <Button
        android:id="@+id/btn_bs_train"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="start training (+20 xp)"
        android:backgroundTint="#212121"
        android:textColor="#FFFFFF"
        app:cornerRadius="12dp" />

</LinearLayout>