<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:padding="8dp"
    tools:context=".activities.CombatPage">

    <!-- Top Left: Round and Combat Log -->
    <LinearLayout
        android:id="@+id/layout_top_left"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/guideline_v"
        app:layout_constraintBottom_toTopOf="@+id/guideline_h">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <TextView
                android:id="@+id/tv_round"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Round X"
                android:textColor="#000000"
                android:textSize="22sp"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/btn_help"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:clickable="true"
                android:focusable="true"
                android:src="@drawable/hint_button"
                app:srcCompat="@drawable/hint_button" />
        </LinearLayout>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="8dp"
            android:background="#1A000000">
            <TextView
                android:id="@+id/tv_combat_log"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="4dp"
                android:text="..."
                android:textColor="#333333"
                android:textSize="14sp"
                android:fontFamily="monospace" />
        </ScrollView>
    </LinearLayout>

    <!-- Top Right: Enemies (Threats) -->
    <LinearLayout
        android:id="@+id/layout_top_right"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="horizontal"
        android:gravity="center"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toEndOf="@+id/guideline_v"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/guideline_h">

        <!-- Enemy 1 Slot -->
        <LinearLayout
            android:id="@+id/enemy_1_slot"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_margin="8dp">
            <TextView
                android:id="@+id/tv_enemy_1_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Enemy 1"
                android:textColor="#212121"
                android:textStyle="bold"
                android:textSize="12sp" />
            <ImageView
                android:id="@+id/iv_enemy_1_selector"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/arrow_down_float"
                android:visibility="invisible" />
            <ImageView
                android:id="@+id/iv_enemy_1_img"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:scaleType="fitCenter"
                android:src="@android:drawable/ic_menu_report_image" />
            <TextView
                android:id="@+id/tv_enemy_1_energy"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ENERGY ..."
                android:textColor="#D32F2F"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Enemy 2 Slot -->
        <LinearLayout
            android:id="@+id/enemy_2_slot"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_margin="8dp">
            <TextView
                android:id="@+id/tv_enemy_2_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Enemy 2"
                android:textColor="#212121"
                android:textStyle="bold"
                android:textSize="12sp" />
            <ImageView
                android:id="@+id/iv_enemy_2_selector"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/arrow_down_float"
                android:visibility="invisible" />
            <ImageView
                android:id="@+id/iv_enemy_2_img"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:scaleType="fitCenter"
                android:src="@android:drawable/ic_menu_report_image" />
            <TextView
                android:id="@+id/tv_enemy_2_energy"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ENERGY ..."
                android:textColor="#D32F2F"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layout_bottom_crew"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:orientation="horizontal"
        android:gravity="bottom"
        android:weightSum="3"
        app:layout_constraintTop_toBottomOf="@+id/guideline_h"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Crew Member 1 -->
        <LinearLayout
            android:id="@+id/layout_crew_1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:padding="2dp">
            <TextView
                android:id="@+id/tv_crew_1_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Name 1"
                android:textColor="#212121"
                android:textStyle="bold"
                android:textSize="12sp" />
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <ImageView
                    android:id="@+id/iv_crew_1_img"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:scaleType="fitCenter"
                    android:src="@android:drawable/ic_menu_report_image" />
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginStart="2dp">
                    <TextView
                        android:id="@+id/tv_crew_1_energy"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ENERGY ..."
                        android:textColor="#388E3C"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <Button
                        android:id="@+id/btn_crew_1_attack"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:backgroundTint="#212121"
                        android:paddingHorizontal="4dp"
                        android:text="ATK"
                        android:textSize="10sp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- Crew Member 2 -->
        <LinearLayout
            android:id="@+id/layout_crew_2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:padding="2dp">
            <TextView
                android:id="@+id/tv_crew_2_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Name 2"
                android:textColor="#212121"
                android:textStyle="bold"
                android:textSize="12sp" />
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <ImageView
                    android:id="@+id/iv_crew_2_img"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:scaleType="fitCenter"
                    android:src="@android:drawable/ic_menu_report_image" />
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginStart="2dp">
                    <TextView
                        android:id="@+id/tv_crew_2_energy"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ENERGY ..."
                        android:textColor="#388E3C"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                    <Button
                        android:id="@+id/btn_crew_2_attack"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="ATK"
                        android:textSize="10sp"
                        android:paddingHorizontal="4dp"
                        android:backgroundTint="#212121" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- Crew Member 3 -->
        <LinearLayout
            android:id="@+id/layout_crew_3"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:padding="2dp">
            <TextView
                android:id="@+id/tv_crew_3_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Name 3"
                android:textColor="#212121"
                android:textStyle="bold"
                android:textSize="12sp" />
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <ImageView
                    android:id="@+id/iv_crew_3_img"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:scaleType="fitCenter"
                    android:src="@android:drawable/ic_menu_report_image" />
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginStart="2dp">
                    <TextView
                        android:id="@+id/tv_crew_3_energy"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ENERGY ..."
                        android:textColor="#388E3C"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                    <Button
                        android:id="@+id/btn_crew_3_attack"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="ATK"
                        android:textSize="10sp"
                        android:paddingHorizontal="4dp"
                        android:backgroundTint="#212121" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline_v"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.45" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline_h"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.55" />

</androidx.constraintlayout.widget.ConstraintLayout>
